<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>El Molino | Sistema Profesional de Pedidos - Pestañas</title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts: Lujo y elegancia -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0a0a0a;
            font-family: 'Inter', sans-serif;
            color: #f0ede8;
            overflow-x: hidden;
        }

        /* Fondo con efecto sutil */
        .bg-gradient {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 10% 20%, #1a1308, #030303);
            z-index: -2;
        }

        /* Partículas animadas */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(rgba(212, 175, 55, 0.15) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: -1;
            animation: floatBg 30s linear infinite;
        }
        @keyframes floatBg {
            0% { background-position: 0 0; }
            100% { background-position: 100px 100px; }
        }

        /* Navegación con pestañas */
        .tabs-nav {
            position: sticky;
            top: 0;
            background: rgba(0, 0, 0, 0.92);
            backdrop-filter: blur(15px);
            padding: 0.8rem 2rem;
            border-bottom: 2px solid rgba(212, 175, 55, 0.4);
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            z-index: 100;
            box-shadow: 0 5px 20px rgba(0,0,0,0.5);
        }
        .tab-btn {
            background: none;
            border: none;
            font-size: 1.1rem;
            font-weight: 600;
            padding: 0.8rem 1.8rem;
            cursor: pointer;
            color: #e8e2d4;
            transition: 0.3s;
            border-radius: 40px;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .tab-btn i {
            font-size: 1.2rem;
        }
        .tab-btn:hover {
            color: #d4af37;
            background: rgba(212, 175, 55, 0.1);
        }
        .tab-btn.active {
            background: #d4af37;
            color: #0a0a0a;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
        }

        /* Contenedor de pestañas */
        .tab-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }
        .tab-pane {
            display: none;
            animation: fadeIn 0.4s ease;
        }
        .tab-pane.active-pane {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Hero dentro de inicio */
        .hero-inicio {
            text-align: center;
            padding: 3rem 1rem;
        }
        .hero-inicio h2 {
            font-size: 3rem;
            font-family: 'Playfair Display', serif;
            color: #d4af37;
        }

        /* Menú grid */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }
        .product-card {
            background: #111111;
            border-radius: 1.5rem;
            overflow: hidden;
            border: 1px solid #2a241b;
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
        }
        .product-card:hover {
            transform: translateY(-8px);
            border-color: #d4af37;
            box-shadow: 0 15px 35px rgba(212, 175, 55, 0.2);
        }
        .product-img {
            width: 100%;
            height: 180px;
            background: #1e1b17;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: #d4af37;
        }
        .product-info {
            padding: 1.2rem;
            text-align: center;
        }
        .product-title {
            font-size: 1.3rem;
            font-weight: 700;
        }
        .product-price {
            color: #d4af37;
            font-weight: 800;
            margin: 0.5rem 0;
        }
        .btn-add {
            background: #d4af37;
            color: #0a0a0a;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            transition: 0.2s;
        }
        .btn-add:hover {
            background: #c7a22b;
        }

        /* Carrito y formulario (pestaña pedido) */
        .cart-sidebar {
            background: #0f0f0f;
            border-radius: 1.5rem;
            border: 1px solid #d4af3740;
            padding: 1.5rem;
            backdrop-filter: blur(8px);
        }
        .cart-items {
            max-height: 300px;
            overflow-y: auto;
            margin: 1rem 0;
        }
        .cart-item {
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            margin-bottom: 0.8rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px dashed #d4af3740;
        }
        .total-cart {
            font-weight: 800;
            border-top: 1px solid #d4af3740;
            padding-top: 0.8rem;
            text-align: right;
            font-size: 1.2rem;
        }
        .checkout-form input, .checkout-form textarea, .checkout-form select {
            width: 100%;
            padding: 0.7rem;
            margin-bottom: 1rem;
            border-radius: 1rem;
            background: #1e1b17;
            border: 1px solid #3a3327;
            color: white;
        }
        .btn-pagar {
            background: #25D366;
            width: 100%;
            padding: 0.8rem;
            border: none;
            border-radius: 1.5rem;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-pagar:hover {
            background: #1da15a;
        }

        /* Botón Admin flotante (solo para creador) */
        .admin-fab {
            position: fixed;
            bottom: 25px;
            left: 25px;
            background: #d4af37;
            color: black;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            cursor: pointer;
            z-index: 1000;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.7);
            transition: 0.3s;
            border: none;
        }
        .admin-fab:hover { transform: scale(1.05); background: #c7a22b; }

        /* Panel Admin (solo visible para el creador) */
        .admin-panel {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.97);
            z-index: 2000;
            backdrop-filter: blur(15px);
            overflow-y: auto;
            padding: 2rem;
        }
        .admin-panel.active {
            display: block;
        }
        .admin-card {
            background: #111;
            border-radius: 2rem;
            padding: 2rem;
            max-width: 1300px;
            margin: 2rem auto;
            border: 1px solid #d4af37;
        }
        .close-admin {
            float: right;
            font-size: 2rem;
            cursor: pointer;
            color: #d4af37;
        }
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
            font-size: 0.8rem;
        }
        .admin-table th, .admin-table td {
            border: 1px solid #d4af3740;
            padding: 8px;
            text-align: left;
        }
        .admin-table th {
            background: #d4af37;
            color: black;
        }
        @media (max-width: 768px) {
            .tabs-nav { gap: 0.8rem; padding: 0.5rem; }
            .tab-btn { padding: 0.5rem 1rem; font-size: 0.9rem; }
            .tab-container { padding: 1rem; }
        }
    </style>
</head>
<body>
<div class="bg-gradient"></div>
<div class="particles"></div>

<!-- Pestañas de navegación -->
<div class="tabs-nav">
    <button class="tab-btn active" data-tab="inicio"><i class="fas fa-home"></i> Inicio</button>
    <button class="tab-btn" data-tab="menu"><i class="fas fa-utensils"></i> Menú</button>
    <button class="tab-btn" data-tab="pedido"><i class="fas fa-shopping-cart"></i> Mi Pedido</button>
</div>

<div class="tab-container">
    <!-- Pestaña Inicio -->
    <div id="inicio" class="tab-pane active-pane">
        <div class="hero-inicio">
            <h2><i class="fas fa-mug-hot"></i> El Molino</h2>
            <p>Café de especialidad · Granos selectos · Guatemala</p>
            <p style="margin-top: 2rem; font-size: 1.1rem;">Disfruta de una experiencia única. Explora nuestro menú y realiza tu pedido.</p>
            <div style="margin-top: 2rem;">
                <i class="fas fa-star" style="color: #d4af37;"></i> <i class="fas fa-star" style="color: #d4af37;"></i> <i class="fas fa-star" style="color: #d4af37;"></i> <i class="fas fa-star" style="color: #d4af37;"></i> <i class="fas fa-star" style="color: #d4af37;"></i>
                <p>“El mejor café de la ciudad” - Clientes satisfechos</p>
            </div>
        </div>
    </div>

    <!-- Pestaña Menú (Catálogo de productos) -->
    <div id="menu" class="tab-pane">
        <h2 style="color: #d4af37; margin-bottom: 1rem;"><i class="fas fa-coffee"></i> Nuestro Menú</h2>
        <div class="menu-grid" id="menuContainer"></div>
    </div>

    <!-- Pestaña Pedido (Carrito + Formulario de pago) -->
    <div id="pedido" class="tab-pane">
        <div class="cart-sidebar">
            <h3><i class="fas fa-shopping-cart"></i> Tu pedido actual</h3>
            <div class="cart-items" id="cartItems"></div>
            <div class="total-cart" id="cartTotal">Total: Q 0.00</div>
            <div class="checkout-form">
                <input type="text" id="clienteNombre" placeholder="Nombre completo" required>
                <input type="text" id="clienteTelefono" placeholder="Teléfono (WhatsApp)" required>
                <input type="text" id="clienteDireccion" placeholder="Dirección de entrega" required>
                <textarea id="notas" placeholder="Notas adicionales (opcional)" rows="2"></textarea>
                <select id="metodoPago">
                    <option value="POS (Tarjeta débito/crédito)">💳 POS (Tarjeta débito/crédito)</option>
                    <option value="Transferencia bancaria">🏦 Transferencia bancaria</option>
                    <option value="Efectivo">💵 Efectivo</option>
                </select>
                <button id="confirmarPedidoBtn" class="btn-pagar"><i class="fab fa-whatsapp"></i> Confirmar y enviar pedido</button>
            </div>
        </div>
    </div>
</div>

<!-- Botón Admin (solo visible para el creador) -->
<button id="adminAccessBtn" class="admin-fab"><i class="fas fa-database"></i></button>

<!-- Panel Admin con base de datos oculta -->
<div id="adminPanel" class="admin-panel">
    <div class="admin-card">
        <span class="close-admin" id="closeAdmin">&times;</span>
        <h2 style="color:#d4af37;"><i class="fas fa-chart-line"></i> Panel de Control - Todos los Pedidos</h2>
        <p>Registros de todos los clientes (Base de datos centralizada en Google Sheets)</p>
        <div style="overflow-x: auto;">
            <table class="admin-table" id="ordersTableAdmin">
                <thead>
                    <tr><th>ID</th><th>Cliente</th><th>Teléfono</th><th>Dirección</th><th>Pedido</th><th>Total</th><th>Método Pago</th><th>Fecha</th></tr>
                </thead>
                <tbody id="adminTableBody"><tr><td colspan="8">Cargando pedidos...</td></tr></tbody>
            </table>
        </div>
        <button id="refreshAdminBtn" style="background:#d4af37; margin-top:1rem; padding:0.5rem 1rem; border-radius:2rem; border:none; font-weight:bold;"><i class="fas fa-sync-alt"></i> Refrescar datos</button>
    </div>
</div>

<script>
    // ======================= CONFIGURACIÓN GOOGLE SHEETS =======================
    // ★★★ REEMPLAZA ESTA URL CON LA URL DE TU GOOGLE APPS SCRIPT ★★★
    // Instrucciones: Crea un Google Sheet > Extensiones > Apps Script > pega el código del backend (se proporciona abajo) > Despliega como web app.
    const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbx_Ejemplo_Reemplazar/exec"; // <--- CAMBIA ESTA URL
    
    // Catálogo de productos (puedes editar nombres, precios e imágenes)
    const products = [
        { id: 1, nombre: "Café Americano", precio: 22, imagen: "fa-mug-hot", descrip: "Intenso y aromático" },
        { id: 2, nombre: "Cappuccino", precio: 28, imagen: "fa-mug-saucer", descrip: "Espuma sedosa" },
        { id: 3, nombre: "Iced Caramel Latte", precio: 35, imagen: "fa-ice-cream", descrip: "Refrescante" },
        { id: 4, nombre: "Torta de Zanahoria", precio: 30, imagen: "fa-cake-candles", descrip: "Frosting de queso" },
        { id: 5, nombre: "Sandwich Bondiola", precio: 45, imagen: "fa-sandwich", descrip: "Ahumado artesanal" },
        { id: 6, nombre: "Latte Especiado", precio: 32, imagen: "fa-leaf", descrip: "Chai & canela" },
        { id: 7, nombre: "Brownie con Helado", precio: 38, imagen: "fa-chocolate-bar", descrip: "Pecanas y dulce de leche" },
        { id: 8, nombre: "Té Chai", precio: 25, imagen: "fa-mug-hot", descrip: "Especias orientales" }
    ];
    
    let cart = [];
    
    // Renderizar menú
    function renderMenu() {
        const container = document.getElementById("menuContainer");
        if(!container) return;
        container.innerHTML = products.map(p => `
            <div class="product-card" data-id="${p.id}">
                <div class="product-img"><i class="fas ${p.imagen}" style="font-size: 4rem;"></i></div>
                <div class="product-info">
                    <div class="product-title">${p.nombre}</div>
                    <div class="product-price">Q ${p.precio}</div>
                    <button class="btn-add" data-id="${p.id}">Agregar al carrito</button>
                </div>
            </div>
        `).join('');
        document.querySelectorAll('.btn-add').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = parseInt(btn.getAttribute('data-id'));
                const product = products.find(p => p.id === id);
                if(product) addToCart(product);
            });
        });
    }
    
    function addToCart(product) {
        const existing = cart.find(item => item.id === product.id);
        if(existing) existing.cantidad++;
        else cart.push({ ...product, cantidad: 1 });
        updateCartUI();
        Swal.fire({ icon: 'success', title: 'Agregado', text: `${product.nombre} añadido`, toast: true, position: 'top-end', showConfirmButton: false, timer: 1200, background: '#1a1a1a', color: '#d4af37' });
    }
    
    function updateCartUI() {
        const cartContainer = document.getElementById("cartItems");
        const totalSpan = document.getElementById("cartTotal");
        if(!cartContainer) return;
        if(cart.length === 0) {
            cartContainer.innerHTML = "<p style='text-align:center'>Carrito vacío</p>";
            totalSpan.innerText = "Total: Q 0.00";
            return;
        }
        let html = "";
        let total = 0;
        cart.forEach(item => {
            const subtotal = item.precio * item.cantidad;
            total += subtotal;
            html += `<div class="cart-item">
                        <span>${item.nombre} x${item.cantidad}</span>
                        <span>Q ${subtotal.toFixed(2)}</span>
                        <button class="remove-item" data-id="${item.id}" style="background:none; border:none; color:#d4af37; cursor:pointer;"><i class="fas fa-trash-alt"></i></button>
                    </div>`;
        });
        cartContainer.innerHTML = html;
        totalSpan.innerText = `Total: Q ${total.toFixed(2)}`;
        document.querySelectorAll('.remove-item').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = parseInt(btn.getAttribute('data-id'));
                cart = cart.filter(item => item.id !== id);
                updateCartUI();
            });
        });
    }
    
    // Envío de pedido a Google Sheets y WhatsApp (número Guatemala)
    const WHATSAPP_NUMBER = "40512960";
    async function enviarPedido() {
        const nombre = document.getElementById("clienteNombre").value.trim();
        const telefono = document.getElementById("clienteTelefono").value.trim();
        const direccion = document.getElementById("clienteDireccion").value.trim();
        const notas = document.getElementById("notas").value;
        const metodoPago = document.getElementById("metodoPago").value;
        
        if(!nombre || !telefono || !direccion) {
            Swal.fire({ icon: 'error', title: 'Campos incompletos', text: 'Completa nombre, teléfono y dirección', background: '#1a1a1a', color: '#d4af37' });
            return;
        }
        if(cart.length === 0) {
            Swal.fire({ icon: 'warning', title: 'Carrito vacío', text: 'Agrega productos al pedido', background: '#1a1a1a', color: '#d4af37' });
            return;
        }
        
        const resumenProductos = cart.map(p => `${p.nombre} x${p.cantidad}`).join(', ');
        const total = cart.reduce((sum, p) => sum + (p.precio * p.cantidad), 0);
        const fecha = new Date().toLocaleString('es-GT');
        
        const orderData = { accion: "registrarPedido", nombre, telefono, direccion, pedido: resumenProductos, total, metodoPago, fecha, notas };
        
        try {
            Swal.fire({ title: 'Procesando...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
            await fetch(GOOGLE_SCRIPT_URL, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(orderData) });
            
            // Enviar WhatsApp
            let numeroWA = telefono.replace(/\s/g, '');
            if(!numeroWA.startsWith('502') && !numeroWA.startsWith('+')) numeroWA = '502' + numeroWA;
            if(!numeroWA.startsWith('+')) numeroWA = '+' + numeroWA;
            let mensajeWA = `🌟 *NUEVO PEDIDO - EL MOLINO* 🌟%0A━━━━━━━━━━━━━━━━━━%0A👤 *Cliente:* ${nombre}%0A📞 *Teléfono:* ${telefono}%0A📍 *Dirección:* ${direccion}%0A📋 *Pedido:* ${resumenProductos}%0A💰 *Total:* Q ${total.toFixed(2)}%0A💳 *Pago:* ${metodoPago}%0A${notas ? `📝 *Notas:* ${notas}%0A` : ''}🕒 *Hora:* ${fecha}%0A✨ *Gracias por preferir El Molino* ✨`;
            window.open(`https://wa.me/${numeroWA}?text=${mensajeWA}`, '_blank');
            
            cart = [];
            updateCartUI();
            document.getElementById("clienteNombre").value = "";
            document.getElementById("clienteTelefono").value = "";
            document.getElementById("clienteDireccion").value = "";
            document.getElementById("notas").value = "";
            Swal.fire({ icon: 'success', title: 'Pedido enviado', text: 'Tu pedido ha sido registrado', background: '#1a1a1a', color: '#d4af37' });
        } catch(error) {
            Swal.fire({ icon: 'error', title: 'Error', text: 'No se pudo guardar el pedido. Revisa la URL de Google Script', background: '#1a1a1a', color: '#d4af37' });
        }
    }
    
    // Cargar todos los pedidos para el admin
    async function loadAllOrdersForAdmin() {
        const tbody = document.getElementById("adminTableBody");
        if(!tbody) return;
        tbody.innerHTML = '<tr><td colspan="8">Cargando base de datos...</td></tr>';
        try {
            const response = await fetch(`${GOOGLE_SCRIPT_URL}?accion=obtenerPedidos`, { method: 'GET' });
            const data = await response.json();
            if(data && data.pedidos && data.pedidos.length > 0) {
                let html = '';
                data.pedidos.forEach((ped, idx) => {
                    html += `<tr>
                        <td>${idx+1}</td>
                        <td>${ped.nombre || ''}</td>
                        <td>${ped.telefono || ''}</td>
                        <td>${ped.direccion || ''}</td>
                        <td>${ped.pedido || ''}</td>
                        <td>Q ${parseFloat(ped.total).toFixed(2)}</td>
                        <td>${ped.metodoPago || ''}</td>
                        <td>${ped.fecha || ''}</td>
                    </tr>`;
                });
                tbody.innerHTML = html;
            } else {
                tbody.innerHTML = '<tr><td colspan="8">No hay pedidos registrados aún</td></tr>';
            }
        } catch(e) {
            tbody.innerHTML = '<tr><td colspan="8">Error al cargar datos. Verifica CORS o URL del script.</td></tr>';
        }
    }
    
    // ======================= SISTEMA DE PESTAÑAS =======================
    const tabs = document.querySelectorAll('.tab-btn');
    const panes = document.querySelectorAll('.tab-pane');
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const targetId = tab.getAttribute('data-tab');
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            panes.forEach(pane => pane.classList.remove('active-pane'));
            const targetPane = document.getElementById(targetId);
            if(targetPane) targetPane.classList.add('active-pane');
        });
    });
    
    // Admin panel
    const adminPanel = document.getElementById("adminPanel");
    const adminBtn = document.getElementById("adminAccessBtn");
    const closeAdmin = document.getElementById("closeAdmin");
    const refreshBtn = document.getElementById("refreshAdminBtn");
    adminBtn.addEventListener("click", () => {
        adminPanel.classList.add("active");
        loadAllOrdersForAdmin();
    });
    closeAdmin.addEventListener("click", () => adminPanel.classList.remove("active"));
    refreshBtn.addEventListener("click", loadAllOrdersForAdmin);
    document.getElementById("confirmarPedidoBtn")?.addEventListener("click", enviarPedido);
    
    renderMenu();
    updateCartUI();
    
    // Nota: Código para Google Apps Script (copia en tu editor de Scripts)
    /*
    function doPost(e) {
      const data = JSON.parse(e.postData.contents);
      const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
      sheet.appendRow([new Date(), data.nombre, data.telefono, data.direccion, data.pedido, data.total, data.metodoPago, data.fecha, data.notas]);
      return ContentService.createTextOutput(JSON.stringify({status:"ok"})).setMimeType(ContentService.MimeType.JSON);
    }
    function doGet(e) {
      const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
      const rows = sheet.getDataRange().getValues();
      const pedidos = [];
      for(let i=1; i<rows.length; i++) {
        pedidos.push({
          fecha: rows[i][0], nombre: rows[i][1], telefono: rows[i][2], direccion: rows[i][3],
          pedido: rows[i][4], total: rows[i][5], metodoPago: rows[i][6], horaRegistro: rows[i][7], notas: rows[i][8]
